DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,pay.smarbiz.sbs
DJANGO_CSRF_TRUSTED_ORIGINS=https://pay.smarbiz.sbs
DJANGO_TIME_ZONE=Europe/Berlin
DJANGO_SECURE_COOKIES=0
DJANGO_HSTS_SECONDS=0
DATABASE_URL=postgresql://apluspay:replace-db-password@db:5432/apluspay
POSTGRES_DB=apluspay
POSTGRES_USER=apluspay
POSTGRES_PASSWORD=replace-db-password

# Apple-Anmeldung für Kunden
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
